{
  "name": "nearley-newick",
  "version": "0.0.2",
  "description": "Newick tree format parser using nearley.js",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "bin": {
    "nearley-newick": "./bin/nearley-newick.js"
  },
  "directories": {
    "lib": "lib",
    "test": "__tests__"
  },
  "files": [
    "bin",
    "lib"
  ],
  "scripts": {
    "compile": "nearleyc lib/newick_grammar.ne -o lib/newick_grammar.cjs",
    "test": "node --test \"__tests__/*.test.js\"",
    "prepublishOnly": "pnpm run compile && pnpm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/notung-agi/nearley-newick.git"
  },
  "keywords": [
    "newick"
  ],
  "author": "BetweenTwoTests",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bugs": {
    "url": "https://github.com/notung-agi/nearley-newick/issues"
  },
  "homepage": "https://github.com/notung-agi/nearley-newick#readme",
  "dependencies": {
    "aguid": "^2.0.0",
    "nearley": "^2.20.1"
  }
}